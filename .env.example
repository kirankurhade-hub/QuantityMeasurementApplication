DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_REPOSITORY=quantitymeasurementapp
IMAGE_TAG=latest

EUREKA_URL=http://localhost:8761/eureka/
SPRING_BOOT_ADMIN_CLIENT_URL=http://localhost:9090
SONARQUBE_URL=http://localhost:9000
SONARQUBE_DB_NAME=sonarqube
SONARQUBE_DB_USERNAME=sonarqube
SONARQUBE_DB_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/quantity_measurement_user
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

MEASUREMENT_DATASOURCE_URL=jdbc:postgresql://localhost:5432/quantity_measurement_measurement
MEASUREMENT_DATASOURCE_USERNAME=postgres
MEASUREMENT_DATASOURCE_PASSWORD=change-me

PAYMENT_DATASOURCE_URL=jdbc:postgresql://localhost:5432/quantity_measurement_payment
PAYMENT_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
PAYMENT_DATASOURCE_USERNAME=postgres
PAYMENT_DATASOURCE_PASSWORD=change-me

APP_JWT_SECRET=replace-with-a-long-base64-or-random-secret
APP_JWT_EXPIRATION_MS=86400000
APP_REDIRECT_URI=http://localhost/auth
APP_OAUTH2_BASE_URI=http://localhost

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@quantitymeasurement.app

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

VITE_API_BASE_URL=http://localhost:8080
VITE_RAZORPAY_KEY_ID=
